# Database
DATABASE_URL=postgresql://itcompany:itcompany@localhost:5432/itcompany

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
# Ollama runs locally on the host machine (NOT in Docker)
# Docker containers access it via host.docker.internal
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=
LLM_SUPPORTS_TOOLS=true

# Logging
LOG_LEVEL=INFO

# Sample data path (auto-set in Docker)
SAMPLE_DATA_PATH=./sample_data
